{
  "name": "welcome2sorrento",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "sorrento-web",
    "studio"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter sorrento run dev\" \"pnpm --filter studio run dev\"",
    "build": "pnpm --filter sorrento run build",
    "format": "prettier --cache --write ."
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ],
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "3.3.3",
    "prettier-plugin-packagejson": "2.5.1"
  }
}